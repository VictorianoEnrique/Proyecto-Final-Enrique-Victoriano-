            app.ArchivoEditFieldLabel.Position = [47 471 52 22];
            app.ArchivoEditFieldLabel.Text = 'Archivo';

            % Create ArchivoEditField
            app.ArchivoEditField = uieditfield(app.UIFigure, 'text');
